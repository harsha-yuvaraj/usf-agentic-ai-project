rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Only allow public uploads to the attachments folder, prevent reading
    // to secure data. The Agent backend uses Admin SDK to bypass these rules.
    match /attachments/{allPaths=**} {
      allow write: if true;
      allow read: if false; 
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}